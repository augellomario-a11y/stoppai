<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#FFFFFF">

    <!-- HEADER CON PULSANTE X -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"
            android:layout_toStartOf="@+id/btn_close_bs">

            <View
                android:id="@+id/view_current_status_badge"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="center_vertical"
                android:background="@drawable/shape_badge_status_red" />

            <TextView
                android:id="@+id/txt_title_number"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginStart="10dp"
                android:ellipsize="end"
                android:singleLine="true" />
        </LinearLayout>

        <TextView
            android:id="@+id/btn_close_bs"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:text="✕"
            android:textSize="24sp"
            android:textColor="#999999"
            android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless" />
    </RelativeLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Valutazione utilizzata anche da ARIA per qualificare il numero"
        android:textSize="11sp"
        android:textColor="#888888"
        android:layout_marginBottom="12dp" />

    <!-- SEZIONE RISPOSTA SMS (SA-057) -->
    <LinearLayout
        android:id="@+id/layout_sms_response"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#F9F9F9"
        android:padding="12dp"
        android:layout_marginBottom="16dp"
        android:visibility="gone">
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💬 RISPOSTA SMS"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#388E3C"
            android:layout_marginBottom="4dp" />
            
        <TextView
            android:id="@+id/txt_sms_response_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nessuna risposta ancora"
            android:textSize="14sp"
            android:textColor="#333333"
            android:fontStyle="italic" />
    </LinearLayout>

    <!-- VOCI MENU -->
    <Button
        android:id="@+id/btn_ai_transcription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📝 TRASCRIZIONE AI"
        android:gravity="start|center_vertical"
        android:paddingStart="16dp"
        android:backgroundTint="#F5F5F5"
        android:textColor="#333333"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btn_da_trattare"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔴 DA TRATTARE"
        android:gravity="start|center_vertical"
        android:paddingStart="16dp"
        android:backgroundTint="#FFEBEE"
        android:textColor="#D32F2F"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btn_spam"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⚫ SPAM"
        android:gravity="start|center_vertical"
        android:paddingStart="16dp"
        android:backgroundTint="#F5F5F5"
        android:textColor="#616161"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btn_attendibile"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="✅ ATTENDIBILE"
        android:gravity="start|center_vertical"
        android:paddingStart="16dp"
        android:backgroundTint="#E8F5E9"
        android:textColor="#388E3C"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btn_note"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📌 NOTE"
        android:gravity="start|center_vertical"
        android:paddingStart="16dp"
        android:backgroundTint="#E3F2FD"
        android:textColor="#1976D2"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btn_add_contact"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="👤 AGGIUNGI AI CONTATTI"
        android:gravity="start|center_vertical"
        android:paddingStart="16dp"
        android:backgroundTint="#F5F5F5"
        android:textColor="#333333"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btn_call_now"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📞 CHIAMA ORA"
        android:gravity="start|center_vertical"
        android:paddingStart="16dp"
        android:backgroundTint="#FFFFFF"
        android:textColor="#333333"
        android:layout_marginBottom="16dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btn_delete_call"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🗑️ ELIMINA DAL REGISTRO"
        android:gravity="start|center_vertical"
        android:paddingStart="16dp"
        android:backgroundTint="#FFEBEE"
        android:textColor="#B71C1C"
        android:layout_marginBottom="12dp" />

</LinearLayout>
