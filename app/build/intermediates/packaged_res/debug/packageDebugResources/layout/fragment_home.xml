<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="StoppAI"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:gravity="center"
        android:layout_gravity="center" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Il tuo bodyguard digitale"
        android:textSize="14sp"
        android:textColor="#888888"
        android:layout_marginBottom="24dp"
        android:gravity="center"
        android:layout_gravity="center" />

    <!-- Box Statistiche CRMs -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">

        <!-- Box Totale -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#F5F5F5"
            android:padding="8dp"
            android:layout_marginEnd="4dp"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Totale"
                android:textSize="12sp"
                android:textColor="#888888" />
            <TextView
                android:id="@+id/ID_HOME_CRM_001"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Box Oggi -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#F5F5F5"
            android:padding="8dp"
            android:layout_marginEnd="4dp"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Oggi"
                android:textSize="12sp"
                android:textColor="#888888" />
            <TextView
                android:id="@+id/ID_HOME_CRM_002"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Box Versione -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#E3F2FD"
            android:padding="8dp"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="v3.6"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1976D2" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SA-048"
                android:textSize="12sp"
                android:textColor="#888888" />
        </LinearLayout>
    </LinearLayout>

    <!-- Protezione Base Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <Switch
            android:id="@+id/ID_HOME_001"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Protezione Base"
            android:textSize="18sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <ImageView
                android:id="@+id/ID_HOME_010_ICON"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_speaker_inactive"
                android:layout_marginEnd="4dp" />
            <TextView
                android:id="@+id/ID_HOME_010_TEXT"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Vol: --"
                android:textSize="14sp"
                android:textColor="#555555" />
        </LinearLayout>
    </LinearLayout>

    <!-- Protezione Totale Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <Switch
            android:id="@+id/ID_HOME_007"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Protezione Totale"
            android:textSize="18sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <ImageView
                android:id="@+id/ID_HOME_011_ICON"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_speaker_inactive"
                android:layout_marginEnd="4dp" />
            <TextView
                android:id="@+id/ID_HOME_011_TEXT"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Vol: --"
                android:textSize="14sp"
                android:textColor="#555555" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/ID_HOME_008"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="14sp"
        android:textColor="#B71C1C"
        android:visibility="gone"
        android:layout_marginBottom="24dp"
        android:paddingStart="4dp" />

    <!-- Area Registro Chiamate -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/ID_HOME_012"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="vertical" />

        <TextView
            android:id="@+id/ID_HOME_013_EMPTY"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📋 Le chiamate appariranno qui"
            android:textColor="#888888"
            android:gravity="center"
            android:layout_gravity="center"
            android:visibility="gone" />
    </FrameLayout>


</LinearLayout>
