<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#FFFFFF">

    <!-- Header Logo PNG Ufficiale (SA-050-LOGO-PNG) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_marginBottom="16dp">

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="120dp"
            android:maxWidth="320dp"
            android:adjustViewBounds="true"
            android:src="@drawable/logo_stoppai"
            android:scaleType="fitCenter"
            android:layout_gravity="center"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Il tuo bodyguard digitale"
            android:textSize="13sp"
            android:textColor="?android:textColorSecondary"
            android:gravity="center" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="v3.9.2-CRM-AddContact — SYNC RUBRICA"
            android:textSize="10sp"
            android:textColor="#3F51B5"
            android:gravity="center"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE"
        android:layout_marginBottom="16dp" />

    <!-- Box Statistiche -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#F8F9FA"
            android:padding="8dp"
            android:layout_marginEnd="6dp"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Totale"
                android:textSize="11sp"
                android:textColor="#666666" />
            <TextView
                android:id="@+id/ID_HOME_STAT_001"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#000000" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#F8F9FA"
            android:padding="8dp"
            android:layout_marginEnd="6dp"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Oggi"
                android:textSize="11sp"
                android:textColor="#666666" />
            <TextView
                android:id="@+id/ID_HOME_STAT_002"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#000000" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#E3F2FD"
            android:padding="8dp"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Referral"
                android:textSize="11sp"
                android:textColor="#1976D2" />
            <TextView
                android:id="@+id/ID_HOME_STAT_003"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1976D2" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE"
        android:layout_marginBottom="16dp" />

    <!-- Sezione Protezione -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">
        <Switch
            android:id="@+id/ID_HOME_001"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Protezione Base"
            android:textSize="16sp" />
        <ImageView
            android:id="@+id/ID_HOME_010_ICON"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_speaker_inactive"
            android:layout_marginEnd="6dp" />
        <TextView
            android:id="@+id/ID_HOME_010_TEXT"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Vel: --"
            android:textSize="13sp"
            android:textColor="#666666" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#DDDDDD"
        android:layout_marginVertical="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">
        <Switch
            android:id="@+id/ID_HOME_007"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Protezione Totale"
            android:textSize="16sp" />
        <ImageView
            android:id="@+id/ID_HOME_011_ICON"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_speaker_inactive"
            android:layout_marginEnd="6dp" />
        <TextView
            android:id="@+id/ID_HOME_011_TEXT"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Vol: --"
            android:textSize="13sp"
            android:textColor="#666666" />
    </LinearLayout>

    <TextView
        android:id="@+id/ID_HOME_008"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="13sp"
        android:textColor="#D32F2F"
        android:visibility="gone"
        android:layout_marginTop="4dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE"
        android:layout_marginVertical="16dp" />

    <!-- Area Registro Chiamate -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/ID_HOME_012"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="vertical" />

        <TextView
            android:id="@+id/ID_HOME_013_EMPTY"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📋 Le chiamate appariranno qui"
            android:textColor="#AAAAAA"
            android:gravity="center"
            android:layout_gravity="center"
            android:visibility="gone" />
    </FrameLayout>

</LinearLayout>
