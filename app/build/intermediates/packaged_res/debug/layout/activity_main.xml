<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="StoppAI - Cruscotto"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <Switch
        android:id="@+id/ID_HOME_001"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Protezione Base"
        android:textSize="18sp"
        android:layout_marginBottom="8dp" />

    <Switch
        android:id="@+id/ID_HOME_007"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Protezione Totale (60 min)"
        android:textSize="18sp"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/ID_HOME_005"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📞 Attiva segreteria StoppAI"
        android:textColor="#FFFFFF"
        android:backgroundTint="#4CAF50"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/ID_HOME_006"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔕 Disattiva segreteria"
        android:textColor="#FFFFFF"
        android:backgroundTint="#888888"
        android:layout_marginBottom="16dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#11000000"
        android:padding="8dp"
        android:layout_marginBottom="16dp">
        
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CONFIGURAZIONE"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>
            
        <TextView android:id="@+id/ID_PERM_001" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="16sp" android:padding="4dp"/>
        <TextView android:id="@+id/ID_PERM_002" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="16sp" android:padding="4dp"/>
        <TextView android:id="@+id/ID_PERM_003" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="16sp" android:padding="4dp"/>
        <TextView android:id="@+id/ID_PERM_004" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="16sp" android:padding="4dp"/>
        <TextView android:id="@+id/ID_PERM_005" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="16sp" android:padding="4dp"/>
        <TextView android:id="@+id/ID_PERM_006" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="16sp" android:padding="4dp" android:text="🔴 Rubrica in caricamento..."/>
    </LinearLayout>

    <Button
        android:id="@+id/ID_HOME_004"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🗑 Svuota registro"
        android:textColor="#FFFFFF"
        android:backgroundTint="#D32F2F"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Registro Chiamate Bloccate:"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/ID_HOME_002"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <TextView
        android:id="@+id/ID_HOME_099"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="StoppAI v0.9 — Deep Silence"
        android:textSize="12sp"
        android:textColor="#AAAAAA"
        android:gravity="center"
        android:layout_marginTop="8dp" />

</LinearLayout>
