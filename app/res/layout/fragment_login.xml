<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#FFFFFF">

    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="80dp"
        android:adjustViewBounds="true"
        android:src="@drawable/logo_stoppai"
        android:scaleType="fitCenter"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Accedi a StoppAI"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center"
        android:textColor="#1a1a1a"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Inserisci la tua email per ricevere il codice di accesso"
        android:textSize="14sp"
        android:gravity="center"
        android:textColor="#888"
        android:layout_marginBottom="32dp"/>

    <!-- STEP 1: Email -->
    <LinearLayout
        android:id="@+id/step_email"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <EditText
            android:id="@+id/edt_email"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="La tua email"
            android:inputType="textEmailAddress"
            android:padding="14dp"
            android:textSize="15sp"
            android:background="@android:drawable/editbox_background"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btn_request_code"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="INVIA CODICE"
            android:textStyle="bold"
            android:padding="14dp"
            android:backgroundTint="#c8a96e"
            android:textColor="#0a0a0f"/>
    </LinearLayout>

    <!-- STEP 2: Codice -->
    <LinearLayout
        android:id="@+id/step_code"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/txt_code_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Codice inviato! Attendi..."
            android:textSize="14sp"
            android:gravity="center"
            android:textColor="#4CAF50"
            android:layout_marginBottom="16dp"/>

        <EditText
            android:id="@+id/edt_code"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Codice a 6 cifre"
            android:inputType="number"
            android:maxLength="6"
            android:padding="14dp"
            android:textSize="24sp"
            android:gravity="center"
            android:letterSpacing="0.3"
            android:background="@android:drawable/editbox_background"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btn_verify_code"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ACCEDI"
            android:textStyle="bold"
            android:padding="14dp"
            android:backgroundTint="#c8a96e"
            android:textColor="#0a0a0f"/>
    </LinearLayout>

    <TextView
        android:id="@+id/txt_error"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textColor="#e53935"
        android:gravity="center"
        android:layout_marginTop="12dp"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/txt_skip"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Continua senza accesso"
        android:textSize="13sp"
        android:textColor="#888"
        android:gravity="center"
        android:layout_marginTop="24dp"
        android:padding="8dp"/>
</LinearLayout>
