<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="40dp">

        <!-- HEADER VERDE SCURO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingVertical="32dp"
            android:background="#1B5E20">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Diventa Partner StoppAI"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Compila il modulo. Ti contatteremo entro 48 ore."
                android:textColor="#B9F6CA"
                android:textSize="14sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- DATI PERSONALI -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DATI PERSONALI"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#1B5E20"
                android:layout_marginBottom="12dp" />

            <TextView android:text="Nome *" android:textSize="12sp" android:textColor="#666666" />
            <EditText android:id="@+id/edt_nome" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/shape_input_note" android:padding="12dp" android:textSize="16sp" android:layout_marginBottom="12dp" />

            <TextView android:text="Cognome *" android:textSize="12sp" android:textColor="#666666" />
            <EditText android:id="@+id/edt_cognome" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/shape_input_note" android:padding="12dp" android:textSize="16sp" android:layout_marginBottom="12dp" />

            <TextView android:text="Email *" android:textSize="12sp" android:textColor="#666666" />
            <EditText android:id="@+id/edt_email" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/shape_input_note" android:padding="12dp" android:textSize="16sp" android:inputType="textEmailAddress" android:layout_marginBottom="12dp" />

            <TextView android:text="Telefono *" android:textSize="12sp" android:textColor="#666666" />
            <EditText android:id="@+id/edt_tel" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/shape_input_note" android:padding="12dp" android:textSize="16sp" android:inputType="phone" android:layout_marginBottom="12dp" />

            <TextView android:text="Data di nascita (GG/MM/AAAA) *" android:textSize="12sp" android:textColor="#666666" />
            <EditText android:id="@+id/edt_nascita" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/shape_input_note" android:padding="12dp" android:textSize="16sp" android:layout_marginBottom="24dp" />

            <!-- DATI FISCALI -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DATI FISCALI"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#1B5E20"
                android:layout_marginBottom="12dp" />

            <TextView android:text="Codice Fiscale *" android:textSize="12sp" android:textColor="#666666" />
            <EditText android:id="@+id/edt_cf" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/shape_input_note" android:padding="12dp" android:textSize="16sp" android:inputType="textCapCharacters" android:layout_marginBottom="12dp" />

            <TextView android:text="Indirizzo *" android:textSize="12sp" android:textColor="#666666" />
            <EditText android:id="@+id/edt_indirizzo" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/shape_input_note" android:padding="12dp" android:textSize="16sp" android:layout_marginBottom="12dp" />

            <TextView android:text="CAP *" android:textSize="12sp" android:textColor="#666666" />
            <EditText android:id="@+id/edt_cap" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/shape_input_note" android:padding="12dp" android:textSize="16sp" android:inputType="number" android:layout_marginBottom="12dp" />

            <TextView android:text="Città *" android:textSize="12sp" android:textColor="#666666" />
            <EditText android:id="@+id/edt_citta" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/shape_input_note" android:padding="12dp" android:textSize="16sp" android:layout_marginBottom="12dp" />

            <TextView android:text="Provincia (ES: RM) *" android:textSize="12sp" android:textColor="#666666" />
            <EditText android:id="@+id/edt_prov" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/shape_input_note" android:padding="12dp" android:textSize="16sp" android:inputType="textCapCharacters" android:maxLength="2" android:layout_marginBottom="24dp" />

            <!-- DATI PAGAMENTO -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DATI PAGAMENTO"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#1B5E20"
                android:layout_marginBottom="12dp" />

            <TextView android:text="IBAN *" android:textSize="12sp" android:textColor="#666666" />
            <EditText android:id="@+id/edt_iban" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/shape_input_note" android:padding="12dp" android:textSize="16sp" android:inputType="textCapCharacters" android:layout_marginBottom="12dp" />

            <TextView android:text="Intestatario conto *" android:textSize="12sp" android:textColor="#666666" />
            <EditText android:id="@+id/edt_intestatario" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/shape_input_note" android:padding="12dp" android:textSize="16sp" android:layout_marginBottom="24dp" />

            <!-- CONSENSI -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONSENSI"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#1B5E20"
                android:layout_marginBottom="12dp" />

            <CheckBox android:id="@+id/chk_regolamento" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Accetto il regolamento affiliazione *" android:textSize="14sp" />
            <CheckBox android:id="@+id/chk_gdpr" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Accetto trattamento dati GDPR *" android:textSize="14sp" />
            <CheckBox android:id="@+id/chk_maggiorenne" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Dichiaro di essere maggiorenne *" android:textSize="14sp" android:layout_marginBottom="32dp" />

            <!-- PULSANTI -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <TextView
                    android:id="@+id/btn_cancel_request"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="ANNULLA"
                    android:textColor="#999999"
                    android:gravity="center"
                    android:padding="16dp"
                    android:focusable="true"
                    android:clickable="true"
                    android:background="?attr/selectableItemBackground" />

                <Button
                    android:id="@+id/btn_send_request_premium"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="INVIA RICHIESTA"
                    android:backgroundTint="#43A047"
                    android:paddingVertical="12dp"
                    android:textColor="#FFFFFF" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
