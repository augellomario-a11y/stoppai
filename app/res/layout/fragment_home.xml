<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="StoppAI - Cruscotto"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/ID_HOME_003"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Oggi: -- bloccate / -- ricevute"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#555555"
        android:background="#11000000"
        android:padding="12dp"
        android:layout_marginBottom="24dp" />

    <Switch
        android:id="@+id/ID_HOME_001"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Protezione Base"
        android:textSize="18sp"
        android:layout_marginBottom="8dp" />

    <Switch
        android:id="@+id/ID_HOME_007"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Protezione Totale"
        android:textSize="18sp"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/ID_HOME_008"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="14sp"
        android:textColor="#B71C1C"
        android:visibility="gone"
        android:layout_marginBottom="24dp"
        android:paddingStart="4dp" />

    <Button
        android:id="@+id/ID_HOME_004"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🗑 Svuota intero registro"
        android:textColor="#FFFFFF"
        android:backgroundTint="#D32F2F"
        android:layout_marginBottom="8dp" />

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <TextView
        android:id="@+id/ID_HOME_099"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="StoppAI v2.9 —\n[TASK-SA-034] — Final Fix"
        android:textSize="12sp"
        android:textColor="#AAAAAA"
        android:gravity="center"
        android:layout_marginTop="8dp" />

</LinearLayout>
