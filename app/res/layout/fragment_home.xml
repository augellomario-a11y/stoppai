<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="StoppAI"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#000000" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Il tuo bodyguard digitale"
        android:textSize="14sp"
        android:textColor="#888888"
        android:layout_marginBottom="24dp" />

    <!-- Box Statistiche CRMs -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">

        <!-- Box Totale -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#F5F5F5"
            android:padding="8dp"
            android:layout_marginEnd="4dp"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Totale"
                android:textSize="12sp"
                android:textColor="#888888" />
            <TextView
                android:id="@+id/ID_HOME_CRM_001"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Box Oggi -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#F5F5F5"
            android:padding="8dp"
            android:layout_marginEnd="4dp"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Oggi"
                android:textSize="12sp"
                android:textColor="#888888" />
            <TextView
                android:id="@+id/ID_HOME_CRM_002"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Box Versione -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#E3F2FD"
            android:padding="8dp"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Versione"
                android:textSize="12sp"
                android:textColor="#888888" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="v3.4 · SA-046"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1976D2" />
        </LinearLayout>
    </LinearLayout>

    <!-- Protezione Base Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <Switch
            android:id="@+id/ID_HOME_001"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Protezione Base"
            android:textSize="18sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:id="@+id/ID_HOME_010_ICON"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="20sp"
                android:layout_marginEnd="4dp" />
            <TextView
                android:id="@+id/ID_HOME_010_TEXT"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Vol: --"
                android:textSize="14sp"
                android:textColor="#555555" />
        </LinearLayout>
    </LinearLayout>

    <!-- Protezione Totale Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <Switch
            android:id="@+id/ID_HOME_007"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Protezione Totale"
            android:textSize="18sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:id="@+id/ID_HOME_011_ICON"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="20sp"
                android:layout_marginEnd="4dp" />
            <TextView
                android:id="@+id/ID_HOME_011_TEXT"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Vol: --"
                android:textSize="14sp"
                android:textColor="#555555" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/ID_HOME_008"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="14sp"
        android:textColor="#B71C1C"
        android:visibility="gone"
        android:layout_marginBottom="24dp"
        android:paddingStart="4dp" />

    <Button
        android:id="@+id/ID_HOME_004"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🗑 Svuota intero registro"
        android:textColor="#FFFFFF"
        android:backgroundTint="#D32F2F"
        android:layout_marginBottom="8dp" />


</LinearLayout>
