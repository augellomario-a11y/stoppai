<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#FAFAFA">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Impostazioni"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#1a1a2e"
            android:layout_marginBottom="20dp" />

        <!-- ===== SEZIONE ACCOUNT ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_settings_bg"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ACCOUNT"
                android:textStyle="bold"
                android:textSize="13sp"
                android:textColor="#c8a96e"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:id="@+id/txt_account_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Non sei loggato"
                android:textSize="14sp"
                android:textColor="#333333"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/btn_account_login"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="Accedi"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:backgroundTint="#c8a96e"
                android:visibility="gone" />

            <Button
                android:id="@+id/btn_account_logout"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="Esci dall'account"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:backgroundTint="#888888"
                android:visibility="gone" />
        </LinearLayout>

        <!-- ===== SEZIONE SEGRETERIA ARIA ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_settings_bg"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SEGRETERIA ARIA"
                android:textStyle="bold"
                android:textSize="13sp"
                android:textColor="#c8a96e"
                android:letterSpacing="0.1"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:id="@+id/txt_aria_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Stato: verificare"
                android:textSize="13sp"
                android:textColor="#666666"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/ID_SETT_OPERATORE"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Operatore: --"
                android:textSize="13sp"
                android:textColor="#666666"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/btn_gestisci_aria"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Gestisci segreteria ARIA"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textAllCaps="false"
                android:backgroundTint="#1a1a2e" />
        </LinearLayout>

        <!-- ===== SEZIONE NUMERI ESTERI ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_settings_bg"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="NUMERI ESTERI"
                android:textStyle="bold"
                android:textSize="13sp"
                android:textColor="#c8a96e"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp"/>

            <!-- Filtro numeri esteri (SHIELD) -->
            <LinearLayout
                android:id="@+id/row_filtro_esteri"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="10dp"
                android:layout_marginBottom="6dp">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Consenti numeri esteri"
                        android:textSize="14sp"
                        android:textColor="#333333"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Se attivo, i numeri internazionali sconosciuti potranno squillare"
                        android:textSize="11sp"
                        android:textColor="#888888"/>
                </LinearLayout>
                <ImageView
                    android:id="@+id/lock_filtro_esteri"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_lock_shield"
                    android:layout_marginEnd="8dp"/>
                <Switch
                    android:id="@+id/switch_consenti_esteri"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- White list prefissi (SHIELD) -->
            <LinearLayout
                android:id="@+id/row_whitelist_esteri"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="10dp"
                android:background="?attr/selectableItemBackground">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="White list prefissi esteri"
                    android:textSize="14sp"
                    android:textColor="#333333"/>
                <ImageView
                    android:id="@+id/lock_whitelist_esteri"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_lock_shield"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ===== SEZIONE MESSAGGIO SEGRETERIA ARIA ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_settings_bg"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="MESSAGGIO SEGRETERIA ARIA"
                android:textStyle="bold"
                android:textSize="13sp"
                android:textColor="#c8a96e"
                android:letterSpacing="0.1"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:id="@+id/txt_aria_msg_attuale"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Messaggio attuale: Standard"
                android:textSize="13sp"
                android:textColor="#666666"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/btn_configura_aria_msg"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="Configura messaggio ARIA"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textAllCaps="false"
                android:backgroundTint="#1a1a2e" />
        </LinearLayout>

        <!-- ===== SEZIONE PERMESSI ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_settings_bg"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="PERMESSI E SISTEMA"
                android:textStyle="bold"
                android:textSize="13sp"
                android:textColor="#c8a96e"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp"/>

            <TextView android:id="@+id/ID_PERM_001" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="14sp" android:padding="6dp"/>
            <TextView android:id="@+id/ID_PERM_002" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="14sp" android:padding="6dp"/>
            <TextView android:id="@+id/ID_PERM_003" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="14sp" android:padding="6dp"/>
            <TextView android:id="@+id/ID_PERM_004" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="14sp" android:padding="6dp"/>
            <TextView android:id="@+id/ID_PERM_005" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="14sp" android:padding="6dp"/>
            <TextView android:id="@+id/ID_PERM_007" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="14sp" android:padding="6dp"/>

            <View android:layout_width="match_parent" android:layout_height="8dp" />

            <TextView android:id="@+id/ID_PERM_006" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="14sp" android:padding="6dp" android:text="🔴 Rubrica in caricamento..."/>
            <ProgressBar
                android:id="@+id/ID_SETT_RUB_PROGRESS"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="6dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- ===== SEZIONE AUDIO ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_settings_bg"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="VOLUME SUONERIA"
                android:textStyle="bold"
                android:textSize="13sp"
                android:textColor="#c8a96e"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="4dp">

                <TextView
                    android:id="@+id/ID_SETT_VOL_MINUS"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="−"
                    android:textSize="22sp"
                    android:gravity="center"
                    android:background="?attr/selectableItemBackgroundBorderless" />

                <SeekBar
                    android:id="@+id/ID_SETT_VOL_SEEK"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="15"
                    android:progressTint="#c8a96e"
                    android:thumbTint="#c8a96e" />

                <TextView
                    android:id="@+id/ID_SETT_VOL_PLUS"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="+"
                    android:textSize="22sp"
                    android:gravity="center"
                    android:background="?attr/selectableItemBackgroundBorderless" />
            </LinearLayout>

            <TextView
                android:id="@+id/ID_SETT_VOL_VAL"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="12 / 15"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#1a1a2e"
                android:gravity="center" />
        </LinearLayout>

        <!-- ===== RESET ===== -->
        <Button
            android:id="@+id/ID_SETT_001"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="Ripristina valori default"
            android:textColor="#888888"
            android:textSize="13sp"
            android:backgroundTint="#EEEEEE"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="32dp" />

    </LinearLayout>
</ScrollView>
