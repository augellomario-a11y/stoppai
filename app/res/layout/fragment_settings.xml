<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">
    <LinearLayout 
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Impostazioni"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <!-- ===== SEZIONE ACCOUNT (login/logout) ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFF8E1"
            android:padding="14dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="👤 ACCOUNT"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/txt_account_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Non sei loggato"
                android:textSize="14sp"
                android:textColor="#666666"
                android:layout_marginBottom="10dp"/>

            <Button
                android:id="@+id/btn_account_login"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔐 Accedi"
                android:textColor="#FFFFFF"
                android:backgroundTint="#4CAF50"
                android:visibility="gone" />

            <Button
                android:id="@+id/btn_account_logout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🚪 Esci dall'account"
                android:textColor="#FFFFFF"
                android:backgroundTint="#E53935"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SEGRETERIA ARIA"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <!-- SEZIONE CONFIGURAZIONE USSD (SA-067-REORG) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#E1F5FE"
            android:padding="12dp"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/ID_SETT_BTN_CONFIG_USSD"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📞 CONFIGURA SEGRETERIA ARIA"
                android:backgroundTint="#0277BD"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⚙️ CONFIGURAZIONE DEVIAZIONE"
                android:textStyle="bold"
                android:textColor="#0277BD"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/ID_SETT_OPERATORE"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Operatore rilevato: --"
                android:textSize="14sp"
                android:textColor="#333333"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Dopo quanti secondi di squillo deviare?"
                android:textSize="12sp"
                android:textColor="#666666" />

            <RadioGroup
                android:id="@+id/ID_SETT_SEC_GROUP"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <RadioButton android:id="@+id/ID_SETT_SEC_5" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="5s" android:layout_weight="1"/>
                <RadioButton android:id="@+id/ID_SETT_SEC_10" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="10s" android:layout_weight="1"/>
                <RadioButton android:id="@+id/ID_SETT_SEC_15" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="15s" android:layout_weight="1" android:checked="true"/>
                <RadioButton android:id="@+id/ID_SETT_SEC_20" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="20s" android:layout_weight="1"/>
            </RadioGroup>
        </LinearLayout>

        <Button
            android:id="@+id/ID_HOME_006"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🚫 Disattiva segreteria"
            android:textColor="#FFFFFF"
            android:backgroundTint="#555555"
            android:layout_marginBottom="24dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#11000000"
            android:padding="8dp"
            android:layout_marginBottom="16dp">
            
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Configurazione sistema"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>
                
            <TextView android:id="@+id/ID_PERM_001" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="16sp" android:padding="4dp"/>
            <TextView android:id="@+id/ID_PERM_002" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="16sp" android:padding="4dp"/>
            <TextView android:id="@+id/ID_PERM_003" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="16sp" android:padding="4dp"/>
            <TextView android:id="@+id/ID_PERM_004" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="16sp" android:padding="4dp"/>
            <TextView android:id="@+id/ID_PERM_005" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="16sp" android:padding="4dp"/>
            <TextView android:id="@+id/ID_PERM_007" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="16sp" android:padding="4dp"/>
            
            <View android:layout_width="match_parent" android:layout_height="8dp" />
            
            <TextView android:id="@+id/ID_PERM_006" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="16sp" android:padding="4dp" android:text="🔴 Rubrica in caricamento..."/>
            <ProgressBar 
                android:id="@+id/ID_SETT_RUB_PROGRESS"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="6dp"
                android:visibility="gone" />
        </LinearLayout>
        
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_marginVertical="16dp" />
        
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔊 Audio"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>
            
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Volume suoneria"
            android:textSize="14sp"
            android:textColor="#666666" />
            
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="8dp">
            
            <TextView
                android:id="@+id/ID_SETT_VOL_MINUS"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="−"
                android:textSize="24sp"
                android:gravity="center"
                android:background="?attr/selectableItemBackgroundBorderless" />
                
            <SeekBar
                android:id="@+id/ID_SETT_VOL_SEEK"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="15" />
                
            <TextView
                android:id="@+id/ID_SETT_VOL_PLUS"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="+"
                android:textSize="24sp"
                android:gravity="center"
                android:background="?attr/selectableItemBackgroundBorderless" />
        </LinearLayout>
        
        <TextView
            android:id="@+id/ID_SETT_VOL_VAL"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="12 / 15"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="16dp" />
            
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/ID_SETT_001"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔄 Ripristina valori default"
            android:textColor="#FFFFFF"
            android:backgroundTint="#888888"
            android:layout_marginTop="16dp" />

    </LinearLayout>
</ScrollView>
