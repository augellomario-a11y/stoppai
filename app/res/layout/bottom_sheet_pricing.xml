<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true"
    android:background="#FAFAFA">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Piani e prezzi"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#1a1a2e"
            android:gravity="center"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Scegli il livello di protezione che fa per te."
            android:textSize="13sp"
            android:textColor="#888888"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <!-- CARD FREE -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_settings_bg"
            android:padding="16dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="FREE"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="#888888"
                android:gravity="center" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="€0"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#888888"
                android:gravity="center"
                android:layout_marginBottom="8dp" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="✓ Protezione base\n✓ Storico chiamate\n✓ SMS standard (30/mese)\n✓ ARIA 3 inoltri/mese"
                android:textSize="13sp"
                android:textColor="#666666"
                android:lineSpacingExtra="4dp" />
        </LinearLayout>

        <!-- CARD PRO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/card_settings_bg">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="PRO"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="#1976D2"
                android:gravity="center" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="€2,99/mese · €18/anno"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1976D2"
                android:gravity="center"
                android:layout_marginBottom="8dp" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="✓ Tutto di FREE +\n✓ Protezione totale\n✓ ARIA illimitato\n✓ 8 voci preset\n✓ SMS personalizzabile illimitato\n✓ Player audio (10/mese)\n✓ Mini CRM completo\n✓ Chat supporto"
                android:textSize="13sp"
                android:textColor="#666666"
                android:lineSpacingExtra="4dp" />

            <Button
                android:id="@+id/btn_pricing_pro"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="Passa a PRO"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1976D2"
                android:layout_marginTop="12dp" />
        </LinearLayout>

        <!-- CARD SHIELD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/card_settings_bg">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SHIELD"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="#c8a96e"
                android:gravity="center" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="€4,99/mese · €29/anno"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#c8a96e"
                android:gravity="center"
                android:layout_marginBottom="8dp" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="✓ Tutto di PRO +\n✓ Messaggio personale registrato\n✓ White list numeri/prefissi\n✓ Player audio illimitato\n✓ Protezione completa"
                android:textSize="13sp"
                android:textColor="#666666"
                android:lineSpacingExtra="4dp" />

            <Button
                android:id="@+id/btn_pricing_shield"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="Passa a SHIELD"
                android:textColor="#1a1a2e"
                android:backgroundTint="#c8a96e"
                android:layout_marginTop="12dp" />
        </LinearLayout>

        <!-- BADGE PIANO ATTUALE -->
        <TextView
            android:id="@+id/txt_pricing_piano_attuale"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Il tuo piano attuale: —"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:gravity="center"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp" />

    </LinearLayout>
</ScrollView>
