<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.StoppAI" parent="Theme.Material3.Light.NoActionBar">
    </style>

    <style name="CustomDialogTheme" parent="Theme.Material3.Light.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowMinWidthMajor">90%</item>
        <item name="android:windowMinWidthMinor">90%</item>
    </style>
    <style name="AppName">StoppAI</style>

    <style name="BottomSheetDialogTheme_Fullscreen" parent="Theme.Design.Light.BottomSheetDialog">
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowSoftInputMode">adjustResize</item>
        <item name="android:windowFullscreen">false</item>
    </style>
</resources>
